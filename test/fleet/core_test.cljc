    ""
    "  remotes:"
    "    - name: kotoba-lang"
    "      url-base: git@github.com:kotoba-lang"
    "    - name: gftdcojp"
    "      url-base: git@github.com:gftdcojp"
    ""
    "  defaults:"
    "    revision: main"
    ""
    "  group-filter: [+kotoba-lang, -datalad, -archived]"
    ""
    "  projects:"
    "    - name: plain"
    "      remote: kotoba-lang"
    "      revision: aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
    "      path: orgs/kotoba-lang/plain"
    "      groups: [kotoba-lang]"
    "    - name: heavy-sub"
    "      remote: kotoba-lang"
    "      revision: bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb"
    "      path: orgs/kotoba-lang/heavy-sub"
    "      clone-depth: 1"
    "      groups: [kotoba-lang]"
    "      submodules: true"
    "    - name: annexed"
    "      remote: gftdcojp"
    "      revision: cccccccccccccccccccccccccccccccccccccccc"
    "      path: orgs/gftdcojp/annexed"
    "      groups: [datalad]"
    "      userdata:"
    "        datalad: true"
    "        annex-remote: b2"
    "    - name: retired"
    "      remote: gftdcojp"
    "      revision: dddddddddddddddddddddddddddddddddddddddd"
    "      path: orgs/gftdcojp/retired"
